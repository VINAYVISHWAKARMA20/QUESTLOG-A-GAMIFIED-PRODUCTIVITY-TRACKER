<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Tactical Spacing & Header Row -->
    <LinearLayout
        android:id="@+id/ll_header_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Centered Month Title -->
        <TextView
            android:id="@+id/tv_month_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="MARCH 2026"
            android:textColor="@color/gold"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="12dp"
            android:shadowColor="#88000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="3"/>

        <!-- Table Header (Reference Match: Capsule Style) -->
        <LinearLayout
            android:id="@+id/ll_table_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bar_background"
            android:orientation="horizontal"
            android:paddingVertical="10dp"
            android:paddingHorizontal="12dp">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="HABITS"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/gold"
                android:layout_marginHorizontal="8dp" />

            <HorizontalScrollView
                android:id="@+id/hsv_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/ll_days_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Header Shadow -->
    <View
        android:id="@+id/header_shadow"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#11FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/ll_header_container" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_habits"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_shadow" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_add_habit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/vibrant_gold"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/black" />

</androidx.constraintlayout.widget.ConstraintLayout>

