<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/quest_card_bg"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_marginBottom="10dp">

    <!-- Top Row: Checkbox + Priority Badge + Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Selection Checkbox -->
        <CheckBox
            android:id="@+id/cb_task_select"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:checked="true"
            android:buttonTint="@color/gold" />

        <!-- Priority Emoji -->
        <TextView
            android:id="@+id/tv_gen_priority_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="🟡"
            android:textSize="16sp" />

        <!-- Priority Badge -->
        <TextView
            android:id="@+id/tv_gen_priority"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/priority_badge_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="MEDIUM"
            android:textColor="@color/gold"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <!-- XP Badge -->
        <TextView
            android:id="@+id/tv_gen_xp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="+100 XP"
            android:textColor="@color/gold"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Task Title -->
    <TextView
        android:id="@+id/tv_gen_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="32dp"
        android:text="Task Title"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Task Details -->
    <TextView
        android:id="@+id/tv_gen_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginStart="32dp"
        android:text="Task details..."
        android:textColor="#AAFFFFFF"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Schedule Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginStart="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_gen_schedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="14/4/2026 at 09:00"
            android:textColor="#88FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

</LinearLayout>
