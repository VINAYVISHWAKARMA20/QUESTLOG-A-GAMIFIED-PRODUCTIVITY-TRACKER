<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gold_border_bg"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Header with AI Icon -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🤖"
                android:textSize="28sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="AI QUEST FORGE"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/ai_card_bg"
            android:orientation="horizontal"
            android:padding="12dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨"
                android:textSize="20sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Describe your major quest and AI will break it down into actionable sub-tasks, auto-scheduled by priority!"
                android:textColor="#BBBBBB"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <!-- Major Task Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="MAJOR QUEST"
            android:textColor="@color/gold"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <EditText
            android:id="@+id/et_major_task"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/edit_text_bg"
            android:hint="e.g. Prepare for Final Exams"
            android:paddingStart="16dp"
            android:textColor="@color/white"
            android:textColorHint="#44FFFFFF"
            android:layout_marginBottom="24dp"
            android:textSize="15sp" />

        <!-- Category -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="CATEGORY REALM"
            android:textColor="@color/gold"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <EditText
            android:id="@+id/et_ai_category"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/edit_text_bg"
            android:hint="Study, Work, Fitness..."
            android:paddingStart="16dp"
            android:textColor="@color/white"
            android:textColorHint="#44FFFFFF"
            android:layout_marginBottom="24dp"
            android:textSize="15sp" />

        <!-- Number of Sub-tasks -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="NUMBER OF SUB-QUESTS"
            android:textColor="@color/gold"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <Spinner
            android:id="@+id/spinner_num_tasks"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/edit_text_bg"
            android:layout_marginBottom="32dp"
            android:paddingStart="16dp"
            android:popupBackground="@color/dark_grey" />

        <!-- Generate Button -->
        <Button
            android:id="@+id/btn_generate_tasks"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/ai_button_bg"
            android:text="⚡ SUMMON AI QUESTS"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"
            android:letterSpacing="0.05"
            android:textAllCaps="false"
            app:elevation="8dp" />

        <!-- Loading indicator (hidden by default) -->
        <LinearLayout
            android:id="@+id/layout_ai_loading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:indeterminateTint="@color/gold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="AI is forging your quests..."
                android:textColor="#88FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
