<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow Layer -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke android:width="4dp" android:color="#44FFD700" />
        </shape>
    </item>
    
    <!-- Core Border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#D9161618" /> <!-- Dark metallic core -->
            <corners android:radius="24dp" />
            <stroke android:width="2dp" android:color="@color/gold" />
        </shape>
    </item>
</layer-list>
